<?xml version="1.0"?>
<robot name="simple_robot_gripper"
       xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ================= BASE ================= -->
  <link name="base_link">
    <visual>
      <geometry>
        <cylinder length="0.2" radius="0.3"/>
      </geometry>
      <material name="gray">
        <color rgba="0.5 0.5 0.5 1"/>
      </material>
    </visual>
  </link>

  <!-- ================= ARM LINK 1 ================= -->
  <link name="arm_link1">
    <visual>
      <geometry>
        <cylinder length="0.2" radius="0.05"/>
      </geometry>
      <origin xyz="0 0 0.1"/>
      <material name="blue">
        <color rgba="0.2 0.4 0.8 1"/>
      </material>
    </visual>
  </link>

  <joint name="joint1" type="revolute">
    <parent link="base_link"/>
    <child link="arm_link1"/>
    <origin xyz="0 0 0.1" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.57" upper="1.57" effort="10.0" velocity="1.0"/>
  </joint>

  <!-- ================= ARM LINK 2 ================= -->
  <link name="arm_link2">
    <visual>
      <geometry>
        <cylinder length="0.2" radius="0.04"/>
      </geometry>
      <origin xyz="0 0 0.1"/>
      <material name="blue"/>
    </visual>
  </link>

  <joint name="joint2" type="revolute">
    <parent link="arm_link1"/>
    <child link="arm_link2"/>
    <origin xyz="0 0 0.2" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="10.0" velocity="1.0"/>
  </joint>

  <!-- ================= GRIPPER LINKS ================= -->

  <link name="left_finger">
    <visual>
      <geometry>
        <box size="0.08 0.02 0.02"/>
      </geometry>
      <material name="black">
        <color rgba="0.1 0.1 0.1 1"/>
      </material>
    </visual>
  </link>

  <link name="right_finger">
    <visual>
      <geometry>
        <box size="0.08 0.02 0.02"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>

  <!-- ================= GRIPPER JOINTS ================= -->

  <joint name="left_finger_joint" type="prismatic">
    <parent link="arm_link2"/>
    <child link="left_finger"/>
    <origin xyz="0 0.05 0" rpy="0 0 0"/>
    <axis xyz="1 -1 0"/>
    <limit lower="0.0" upper="0.04" effort="5.0" velocity="0.2"/>
  </joint>

  <joint name="right_finger_joint" type="prismatic">
    <parent link="arm_link2"/>
    <child link="right_finger"/>
    <origin xyz="0 -0.05 0" rpy="0 0 0"/>
    <axis xyz="1 1 0"/>
    <limit lower="0.0" upper="0.04" effort="5.0" velocity="0.2"/>
  </joint>

  <!-- ================= ROS2 CONTROL ================= -->

  <ros2_control name="SimpleSystem" type="system">

    <hardware>
      <plugin>mock_components/GenericSystem</plugin>
    </hardware>

    <joint name="joint1">
      <command_interface name="position"/>
      <state_interface name="position"/>
    </joint>

    <joint name="joint2">
      <command_interface name="position"/>
      <state_interface name="position"/>
    </joint>

    <joint name="left_finger_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
    </joint>

    <joint name="right_finger_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
    </joint>

  </ros2_control>

</robot>